library(dplyr)
library(tibble)
library(clipr)
# 1. Capture the summary object
s <- summary(model_bloom)
# 2. Extract Fixed Effects (The main coefficients)
fixed_df <- as.data.frame(s$fixed) %>%
rownames_to_column("Term") %>%
mutate(Type = "Fixed Effect")
# 3. Extract Random Effects (SDs and Correlations only)
# This handles multiple groups automatically
random_df <- do.call(rbind, lapply(s$random, as.data.frame)) %>%
rownames_to_column("Term") %>%
mutate(Type = "Random Effect (SD/Cor)")
library(dplyr)
library(tibble)
library(clipr)
# 1. Capture the summary object
s <- summary(model_bloom)
# 2. Fixed Effects
fixed_df <- as.data.frame(s$fixed) %>%
rownames_to_column("Term") %>%
mutate(Type = "Fixed Effect")
# 3. Random Effects (The Fix)
# We force the result of do.call into a data.frame immediately
random_raw <- do.call(rbind, lapply(s$random, as.data.frame))
random_df  <- as.data.frame(random_raw) %>%
rownames_to_column("Term") %>%
mutate(Type = "Random Effect (SD/Cor)")
# 4. Family Specific (Sigma/Residuals)
spec_df <- as.data.frame(s$spec_pars) %>%
rownames_to_column("Term") %>%
mutate(Type = "Family Specific")
# 5. Bind and Copy
final_table <- bind_rows(fixed_df, random_df, spec_df)
# Write to clipboard for Excel
write_clip(final_table)
write_clip(final_table)
